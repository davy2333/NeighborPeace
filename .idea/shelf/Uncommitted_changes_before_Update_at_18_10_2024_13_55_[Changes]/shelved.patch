<+><?xml version=\"1.0\" encoding=\"utf-8\"?>\r\n<androidx.constraintlayout.widget.ConstraintLayout\r\n    xmlns:android=\"http://schemas.android.com/apk/res/android\"\r\n    xmlns:app=\"http://schemas.android.com/apk/res-auto\"\r\n    xmlns:tools=\"http://schemas.android.com/tools\"\r\n    android:id=\"@+id/main\"\r\n    android:layout_width=\"match_parent\"\r\n    android:layout_height=\"match_parent\"\r\n    tools:context=\".Profile\"\r\n    android:background=\"@android:color/black\">\r\n\r\n    <!-- Icono de Flecha para retroceder -->\r\n    <ImageView\r\n        android:id=\"@+id/backArrow\"\r\n        android:layout_width=\"48dp\"\r\n        android:layout_height=\"48dp\"\r\n        android:src=\"?attr/homeAsUpIndicator\"\r\n        android:contentDescription=\"@string/retroceder\"\r\n        app:layout_constraintTop_toTopOf=\"parent\"\r\n        app:layout_constraintStart_toStartOf=\"parent\"\r\n        android:layout_marginTop=\"32dp\"\r\n        android:layout_marginStart=\"16dp\"\r\n        app:tint=\"@color/logo_color\" />\r\n\r\n    <!-- Texto HOME -->\r\n    <TextView\r\n        android:id=\"@+id/homeText\"\r\n        android:layout_width=\"wrap_content\"\r\n        android:layout_height=\"wrap_content\"\r\n        android:text=\"HOME\"\r\n        android:textColor=\"#5A1C84\"\r\n        android:textSize=\"18sp\"\r\n        app:layout_constraintStart_toEndOf=\"@id/backArrow\"\r\n        app:layout_constraintTop_toTopOf=\"@id/backArrow\"\r\n        android:layout_marginStart=\"8dp\"\r\n        android:layout_marginTop=\"16dp\" />\r\n\r\n    <!-- Título: Perfil -->\r\n    <TextView\r\n        android:id=\"@+id/titleProfile\"\r\n        android:layout_width=\"wrap_content\"\r\n        android:layout_height=\"wrap_content\"\r\n        android:text=\"Perfil\"\r\n        android:textColor=\"#FFFFFF\"\r\n        android:textSize=\"24sp\"\r\n        android:textStyle=\"bold\"\r\n        app:layout_constraintTop_toBottomOf=\"@id/homeText\"\r\n        app:layout_constraintStart_toStartOf=\"parent\"\r\n        android:layout_marginStart=\"16dp\"\r\n        android:layout_marginTop=\"24dp\" />\r\n\r\n    <!-- Imagen de perfil -->\r\n    <ImageView\r\n        android:id=\"@+id/profileImage\"\r\n        android:layout_width=\"100dp\"\r\n        android:layout_height=\"100dp\"\r\n        android:layout_marginTop=\"24dp\"\r\n        android:src=\"@drawable/ic_launcher_profile\"\r\n        android:contentDescription=\"Imagen de perfil\"\r\n        android:scaleType=\"centerCrop\"\r\n        android:background=\"@drawable/circular_border\"\r\n        app:layout_constraintTop_toBottomOf=\"@id/titleProfile\"\r\n        app:layout_constraintStart_toStartOf=\"parent\"\r\n        app:layout_constraintEnd_toEndOf=\"parent\"\r\n        android:layout_marginStart=\"16dp\"\r\n        android:layout_marginEnd=\"16dp\" />\r\n\r\n    <!-- Email Label -->\r\n    <TextView\r\n        android:id=\"@+id/emailLabel\"\r\n        android:layout_width=\"0dp\"\r\n        android:layout_height=\"wrap_content\"\r\n        android:text=\"Email\"\r\n        android:textColor=\"#FFFFFF\"\r\n        android:textSize=\"16sp\"\r\n        app:layout_constraintTop_toBottomOf=\"@id/profileImage\"\r\n        app:layout_constraintStart_toStartOf=\"parent\"\r\n        app:layout_constraintEnd_toStartOf=\"@id/emailValue\"\r\n        android:layout_marginTop=\"16dp\"\r\n        android:layout_marginEnd=\"8dp\" />\r\n\r\n    <!-- Email Value -->\r\n    <TextView\r\n        android:id=\"@+id/emailValue\"\r\n        android:layout_width=\"0dp\"\r\n        android:layout_height=\"wrap_content\"\r\n        android:text=\"walterflores@gmail.com\"\r\n        android:textColor=\"#A9A9A9\"\r\n        android:textSize=\"16sp\"\r\n        app:layout_constraintTop_toTopOf=\"@id/emailLabel\"\r\n        app:layout_constraintStart_toEndOf=\"@id/emailLabel\"\r\n        app:layout_constraintEnd_toEndOf=\"parent\"\r\n        android:layout_marginStart=\"8dp\" />\r\n\r\n    <!-- Línea divisoria entre Email y Nombre -->\r\n    <View\r\n        android:layout_width=\"0dp\"\r\n        android:layout_height=\"1dp\"\r\n        android:background=\"#FFFFFF\"\r\n        app:layout_constraintTop_toBottomOf=\"@id/emailLabel\"\r\n        app:layout_constraintStart_toStartOf=\"parent\"\r\n        app:layout_constraintEnd_toEndOf=\"parent\"\r\n        android:layout_marginTop=\"16dp\" />\r\n\r\n    <!-- Nombre -->\r\n    <TextView\r\n        android:id=\"@+id/nameLabel\"\r\n        android:layout_width=\"0dp\"\r\n        android:layout_height=\"wrap_content\"\r\n        android:text=\"Nombre\"\r\n        android:textColor=\"#FFFFFF\"\r\n        android:textSize=\"16sp\"\r\n        app:layout_constraintTop_toBottomOf=\"@id/emailLabel\"\r\n        app:layout_constraintStart_toStartOf=\"parent\"\r\n        app:layout_constraintEnd_toStartOf=\"@id/nameValue\"\r\n        android:layout_marginTop=\"16dp\"\r\n        android:layout_marginEnd=\"8dp\" />\r\n\r\n    <TextView\r\n        android:id=\"@+id/nameValue\"\r\n        android:layout_width=\"0dp\"\r\n        android:layout_height=\"wrap_content\"\r\n        android:layout_marginStart=\"50dp\"\r\n        android:text=\"Walter\"\r\n        android:textColor=\"#A9A9A9\"\r\n        android:textSize=\"16sp\"\r\n        app:layout_constraintEnd_toStartOf=\"@id/editNameButton\"\r\n        app:layout_constraintStart_toEndOf=\"@id/nameLabel\"\r\n        app:layout_constraintTop_toTopOf=\"@id/nameLabel\" />\r\n\r\n    <ImageButton\r\n        android:id=\"@+id/editNameButton\"\r\n        android:layout_width=\"wrap_content\"\r\n        android:layout_height=\"wrap_content\"\r\n        android:background=\"@drawable/ic_right_arrow\"\r\n        android:contentDescription=\"Editar nombre\"\r\n        app:layout_constraintStart_toEndOf=\"@id/nameValue\"\r\n        app:layout_constraintEnd_toEndOf=\"parent\"\r\n        app:layout_constraintTop_toTopOf=\"@id/nameLabel\"\r\n        android:layout_marginStart=\"8dp\"\r\n        android:layout_marginEnd=\"8dp\" />\r\n\r\n    <!-- Línea divisoria entre Nombre y Ubicación -->\r\n    <View\r\n        android:layout_width=\"0dp\"\r\n        android:layout_height=\"1dp\"\r\n        android:background=\"#FFFFFF\"\r\n        app:layout_constraintTop_toBottomOf=\"@id/nameLabel\"\r\n        app:layout_constraintStart_toStartOf=\"parent\"\r\n        app:layout_constraintEnd_toEndOf=\"parent\"\r\n        android:layout_marginTop=\"16dp\" />\r\n\r\n    <!-- Ubicación -->\r\n    <TextView\r\n        android:id=\"@+id/locationLabel\"\r\n        android:layout_width=\"0dp\"\r\n        android:layout_height=\"wrap_content\"\r\n        android:text=\"Ubicación\"\r\n        android:textColor=\"#FFFFFF\"\r\n        android:textSize=\"16sp\"\r\n        app:layout_constraintTop_toBottomOf=\"@id/nameLabel\"\r\n        app:layout_constraintStart_toStartOf=\"parent\"\r\n        app:layout_constraintEnd_toStartOf=\"@id/locationValue\"\r\n        android:layout_marginTop=\"16dp\"\r\n        android:layout_marginEnd=\"8dp\" />\r\n\r\n    <TextView\r\n        android:id=\"@+id/locationValue\"\r\n        android:layout_width=\"0dp\"\r\n        android:layout_height=\"wrap_content\"\r\n        android:text=\"Santa Ana\"\r\n        android:textColor=\"#A9A9A9\"\r\n        android:textSize=\"16sp\"\r\n        app:layout_constraintTop_toTopOf=\"@id/locationLabel\"\r\n        app:layout_constraintStart_toEndOf=\"@id/locationLabel\"\r\n        app:layout_constraintEnd_toEndOf=\"parent\"\r\n        android:layout_marginStart=\"8dp\" />\r\n\r\n    <!-- Línea divisoria entre Ubicación y Teléfono -->\r\n    <View\r\n        android:layout_width=\"0dp\"\r\n        android:layout_height=\"1dp\"\r\n        android:background=\"#FFFFFF\"\r\n        app:layout_constraintTop_toBottomOf=\"@id/locationLabel\"\r\n        app:layout_constraintStart_toStartOf=\"parent\"\r\n        app:layout_constraintEnd_toEndOf=\"parent\"\r\n        android:layout_marginTop=\"16dp\" />\r\n\r\n    <!-- Teléfono -->\r\n    <TextView\r\n        android:id=\"@+id/phoneLabel\"\r\n        android:layout_width=\"0dp\"\r\n        android:layout_height=\"wrap_content\"\r\n        android:text=\"Teléfono\"\r\n        android:textColor=\"#FFFFFF\"\r\n        android:textSize=\"16sp\"\r\n        app:layout_constraintTop_toBottomOf=\"@id/locationLabel\"\r\n        app:layout_constraintStart_toStartOf=\"parent\"\r\n        app:layout_constraintEnd_toStartOf=\"@id/phoneValue\"\r\n        android:layout_marginTop=\"16dp\"\r\n        android:layout_marginEnd=\"8dp\" />\r\n\r\n    <TextView\r\n        android:id=\"@+id/phoneValue\"\r\n        android:layout_width=\"0dp\"\r\n        android:layout_height=\"wrap_content\"\r\n        android:text=\"7089 5467\"\r\n        android:textColor=\"#A9A9A9\"\r\n        android:textSize=\"16sp\"\r\n        app:layout_constraintTop_toTopOf=\"@id/phoneLabel\"\r\n        app:layout_constraintStart_toEndOf=\"@id/phoneLabel\"\r\n        app:layout_constraintEnd_toEndOf=\"parent\"\r\n        android:layout_marginStart=\"8dp\" />\r\n\r\n</androidx.constraintlayout.widget.ConstraintLayout>\r\n
